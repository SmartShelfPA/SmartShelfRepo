# Copy this file to `.env` in the same folder as docker-compose.yml and fill in values.
# Docker Compose reads `.env` automatically for variable substitution.

# Get your authtoken: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# --- Real email (password reset + future notifications) ---
# 1. Copy this file to `.env` in the SmartShelfRepo folder (next to docker-compose.yml).
# 2. Set EMAIL_BACKEND to SMTP (default in Docker is console-only — emails print in backend logs).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-address@gmail.com
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords).
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=your-address@gmail.com
# After editing: docker compose up -d --force-recreate backend
# Test: app → Forgot password → enter the email used at sign-up → check inbox (and spam).

# Dev only: skip login for N minutes after Django/backend process starts (uses superuser or first user).
# Use 0 in production. Restart backend after changing.
# AUTH_FREE_FOR_MINUTES=5
# Optional: UserProfile primary key to impersonate when bypass is on
# AUTH_BYPASS_USER_ID=

# After running: docker compose --profile tunnel up -d
# Find your public HTTPS URL in the ngrok container logs or at http://localhost:4040
# Then point the app API to your tunnel, e.g. in frontend smartshelf/services/api.ts:
#   API_BASE_URL = 'https://YOUR-SUBDOMAIN.ngrok-free.app/api'
